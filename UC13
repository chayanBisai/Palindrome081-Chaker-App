import java.util.Stack;
public class PalindromePerformance {
    public static boolean twoPointerPalindrome(String str) {
        int start = 0;
        int end = str.length() - 1;
        while (start < end) {
            if (str.charAt(start) != str.charAt(end))
                return false;
            start++;
            end--;
        }
        return true;
    }
    public static boolean stackPalindrome(String str) {
        Stack<Character> stack = new Stack<>();
        for (char c : str.toCharArray()) {
            stack.push(c);
        }

        for (char c : str.toCharArray()) {
            if (c != stack.pop())
                return false;
        }
        return true;
    }
    public static void main(String[] args) {
        String input = "madam";
        long start1 = System.nanoTime();
        twoPointerPalindrome(input);
        long end1 = System.nanoTime();
        long start2 = System.nanoTime();
        stackPalindrome(input);
        long end2 = System.nanoTime();
        System.out.println("Two Pointer Execution Time: " + (end1 - start1) + " ns");
        System.out.println("Stack Execution Time: " + (end2 - start2) + " ns");
    }
}
